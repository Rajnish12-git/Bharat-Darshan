rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Users can create their own profile
      allow create: if isOwner(userId);
      // Anyone can read user profiles (e.g., for display names)
      allow read: if true;
      // Users can only update or delete their own profile
      allow update, delete: if isOwner(userId);

      // Rule for the nested bookings collection
      match /bookings/{bookingId} {
        // Only the owner of the user profile can read, write, update, or delete their own bookings.
        allow read, write: if isOwner(userId);
      }
    }
  }
}
