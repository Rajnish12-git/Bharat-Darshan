rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Users can create their own profile
      allow create: if isOwner(userId);
      // Anyone can read user profiles (e.g., for display names)
      allow read: if true;
      // Users can only update or delete their own profile
      allow update, delete: if isOwner(userId);
    }

    match /bookings/{bookingId} {
      // Allow creation by any authenticated user (including anonymous guests)
      allow create: if isSignedIn();
      
      // Allow users to read a list of their own bookings
      allow list: if request.auth.uid == request.query.filters.userId.string_value;

      // Allow users to read, update, or delete a single one of their own bookings
      allow get, update, delete: if isOwner(resource.data.userId);
    }
  }
}
