/**
 * Core Philosophy: This ruleset establishes a clear boundary between public, read-only
 * content and private, user-owned data. Information about Indian states and monuments
 * is publicly accessible to all users, including those not signed in, but cannot be
 * modified by clients. User-specific data, such as profiles and search history, is
 * strictly confined to the authenticated user who owns it.
 *
 * Data Structure: The database is organized into two primary top-level collections:
 * `/states` for public geographical and cultural information, and `/users` for private
 * user data. Each user's data, including their `searchHistory`, is nested under their
 * unique user document (`/users/{userId}`), enabling simple and secure path-based
 * ownership rules.
 *
 * Key Security Decisions:
 * - Public Data is Read-Only: The `/states` and `/states/{stateId}/monuments`
 *   collections are world-readable to provide the app's core information. All client
 *   write operations (`create`, `update`, `delete`) are disabled to protect data
 *   integrity, assuming this data is populated by a trusted admin backend.
 * - Strict User Privacy: The `/users` collection cannot be listed, preventing any
 *   user from discovering other users on the platform.
 * - User Data Ownership: A user has full control over their own document and
 *   subcollections (e.g., `/users/{userId}/searchHistory`), but cannot access,
 *   modify, or even know about the data of any other user.
 * - Prototyping Flexibility: While authorization is strict, data shape validation
 *   is minimal. Rules only validate fields essential for maintaining ownership and
 *   relational integrity (e.g., `userId` fields), allowing the application schema
 *   to evolve without requiring rule changes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership security model.
     * @param userId The UID to check against the authenticated user.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for safe updates and deletes.
     * Prevents operations on documents that do not exist.
     * @param userId The UID to check against the authenticated user.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * @description Manages access to the public information about Indian states.
     * This data is intended to be read-only for all clients.
     * @path /states/{stateId}
     * @allow (get) Anyone, including unauthenticated users, can read a state's details.
     * @deny (create) No client, authenticated or not, can create a new state document.
     * @principle Public read with locked-down writes to ensure data integrity.
     */
    match /states/{stateId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      /**
       * @description Manages access to the public monuments subcollection within a state.
       * This data is also intended to be read-only for all clients.
       * @path /states/{stateId}/monuments/{monumentId}
       * @allow (list) Anyone can retrieve a list of monuments for a given state.
       * @deny (update) No client can modify an existing monument document.
       * @principle Inherits the public read-only model from its parent collection.
       */
      match /monuments/{monumentId} {
        allow get, list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    /**
     * @description Secures user profile documents. Each user can create their own
     * profile, and subsequently only they can read or modify it. Listing all users
     * is explicitly forbidden to protect user privacy.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own profile document.
     * @deny (get) A user trying to read another user's profile document.
     * @deny (list) Any attempt to query the `/users` collection is blocked.
     * @principle Enforces a strict self-service and ownership model for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Secures a user's private search history. Only the owning user
       * can create, read, update, or delete their own search history entries.
       * @path /users/{userId}/searchHistory/{searchHistoryId}
       * @allow (create) User 'abc' can add a search record to `/users/abc/searchHistory`.
       * @deny (list) User 'xyz' cannot list records from `/users/abc/searchHistory`.
       * @principle Restricts access to a user's own private data tree.
       */
      match /searchHistory/{searchHistoryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}