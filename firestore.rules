rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Users can create their own profile
      allow create: if isOwner(userId);
      // Anyone can read user profiles (e.g., for display names)
      allow read: if true;
      // Users can only update or delete their own profile
      allow update, delete: if isOwner(userId);
    }

    match /bookings/{bookingId} {
      // Allow creation by anyone (guests or signed-in users)
      allow create: if isSignedIn();
      
      // Allow users to read their own bookings
      allow read: if isOwner(resource.data.userId);
      
      // Allow users to update or delete their own bookings
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}
