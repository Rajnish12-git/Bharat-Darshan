{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's public profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the user profile was created."
        }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "Booking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Booking",
      "type": "object",
      "description": "Represents a booking request for hotels or tour guides.",
      "properties": {
        "bookingId": {
          "type": "string",
          "description": "Unique identifier for the booking entity."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who created the booking, or 'guest'."
        },
        "bookingType": {
          "type": "string",
          "description": "The type of booking.",
          "enum": ["hotel", "guide"]
        },
        "monumentName": {
          "type": "string",
          "description": "Name of the monument the booking is related to."
        },
        "city": {
          "type": "string",
          "description": "City of the monument."
        },
        "state": {
          "type": "string",
          "description": "State of the monument."
        },
        "visitDate": {
          "type": "string",
          "description": "Date of the intended visit or check-in.",
          "format": "date-time"
        },
        "peopleCount": {
          "type": "number",
          "description": "Number of people in the booking."
        },
        "hotelCategory": {
          "type": "string",
          "description": "Category of the hotel if booking type is 'hotel'.",
          "enum": ["budget", "standard", "luxury"]
        },
        "nights": {
          "type": "number",
          "description": "Number of nights for a hotel booking."
        },
        "guideLanguage": {
          "type": "string",
          "description": "Language preference for a tour guide booking."
        },
        "tourDuration": {
          "type": "string",
          "description": "Duration of the tour for a guide booking.",
          "enum": ["half-day", "full-day"]
        },
        "userName": {
          "type": "string",
          "description": "Full name of the user making the booking."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user making the booking.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the user making the booking."
        },
        "status": {
          "type": "string",
          "description": "Status of the booking.",
          "enum": ["pending", "confirmed"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the booking was created.",
          "format": "date-time"
        }
      },
      "required": [
        "bookingType",
        "monumentName",
        "visitDate",
        "peopleCount",
        "userName",
        "email",
        "phone",
        "status",
        "createdAt",
        "userId"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores public user profile information."
        }
      },
      {
        "path": "/users/{userId}/bookings/{bookingId}",
        "definition": {
          "entityName": "Booking",
          "schema": {
            "$ref": "#/backend/entities/Booking"
          },
          "description": "Stores booking requests for a specific user. The 'bookingId' is the document ID.",
          "params": [
            {
              "name": "userId",
              "description": "The UID of the user."
            },
            {
              "name": "bookingId",
              "description": "Unique identifier for each booking document."
            }
          ]
        }
      }
    ]
  }
}
